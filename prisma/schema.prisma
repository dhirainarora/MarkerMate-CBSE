generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  submissions  Submission[]
}

model Submission {
  id                  String            @id @default(cuid())
  userId              String
  subject             String
  questionText        String
  answerText          String
  markWeight          Int
  topic               String?
  status              String
  extractedQuestion   String?
  extractedAnswer     String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id])
  assets              SubmissionAsset[]
  gradingResult       GradingResult?
}

model SubmissionAsset {
  id           String      @id @default(cuid())
  submissionId String
  kind         String
  fileName     String
  filePath     String
  mimeType     String
  createdAt    DateTime    @default(now())
  submission   Submission  @relation(fields: [submissionId], references: [id])
}

model RubricTemplate {
  id                    String   @id @default(cuid())
  subject               String
  questionType          String
  markWeight            Int
  expectedStructure     String
  keyPoints             Json
  presentationChecklist Json
  sampleExpectations    Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model GradingResult {
  id                     String     @id @default(cuid())
  submissionId           String     @unique
  awardedMarks           Float
  maxMarks               Int
  overallVerdict         String
  strengths              Json
  missingPoints          Json
  improvementSuggestions Json
  idealAnswerApproach    String
  rewrittenSampleAnswer  String
  confidence             Float
  needsManualReview      Boolean
  justification          String
  createdAt              DateTime   @default(now())
  submission             Submission @relation(fields: [submissionId], references: [id])
}
